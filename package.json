{
  "name": "cwcm-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @cwcm/web",
    "dev:api": "npm run dev -w @cwcm/api",
    "build:web": "npm run build -w @cwcm/web",
    "build:api": "npm run build -w @cwcm/api",
    "build": "npm run build:web && npm run build:api",
    "lint:web": "npm run lint -w @cwcm/web",
    "lint:api": "npm run lint -w @cwcm/api",
    "lint": "npm run lint:web && npm run lint:api",
    "format": "prettier --write .",
    "db:prepare": "node scripts/ensure-postgres-db.mjs",
    "prisma:generate": "npm run prisma:generate -w @cwcm/api",
    "prisma:migrate": "npm run prisma:migrate -w @cwcm/api",
    "prisma:push": "npm run prisma:push -w @cwcm/api"
  },
  "devDependencies": {
    "pg": "^8.16.3",
    "prettier": "^3.7.3"
  }
}
